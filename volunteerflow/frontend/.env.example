# VolunteerFlow Frontend — Environment Variables
# Copy this file to .env.local and fill in real values.
# Only NEXT_PUBLIC_* variables are exposed to the browser.

# Backend API base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# ── Payments (PayPal) ──────────────────────────────────────────────────────────
# Your PayPal app Client ID (from developer.paypal.com → My Apps)
# Must be NEXT_PUBLIC_ so it's available in the browser for the PayPal SDK
NEXT_PUBLIC_PAYPAL_CLIENT_ID=AYour_PayPal_Client_ID_Here
