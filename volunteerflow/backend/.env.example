# VolunteerFlow Backend — Environment Variables
# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# Application environment: development | production | test
NODE_ENV=development

# Port the Express server will listen on
PORT=3001

# Allowed CORS origin (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# Your frontend URL — used in email links and Stripe redirect URLs
FRONTEND_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────────────────────
# PostgreSQL connection string.
# Run `docker compose up db` to start the bundled Postgres container.
DATABASE_URL=postgresql://volunteerflow:volunteerflow123@localhost:5432/volunteerflow

# ── Auth ──────────────────────────────────────────────────────────────────────
# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-secret

# How long issued JWTs remain valid (e.g. 7d, 24h, 1h)
JWT_EXPIRES_IN=7d

# ── Staff / Employee Dashboard ─────────────────────────────────────────────────
# Separate JWT secret for internal staff sessions (MUST differ from JWT_SECRET).
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
STAFF_JWT_SECRET=replace-with-a-different-64-char-random-hex-string

# ── Seed ──────────────────────────────────────────────────────────────────────
# Password for the default admin account (admin@volunteerflow.com).
# Only used when the DB is seeded for the first time.
SEED_ADMIN_PASSWORD=admin123

# ── File Storage (Supabase Storage) ──────────────────────────────────────────
# Your Supabase project URL (Settings > API > Project URL)
SUPABASE_URL=https://your-project-ref.supabase.co
# Service role key — NEVER expose this in the frontend (Settings > API > service_role)
SUPABASE_SERVICE_KEY=your-service-role-key
# Name of the storage bucket (create it in Supabase Dashboard > Storage, set to Public)
SUPABASE_BUCKET=volunteerflow-files

# ── QR Scan Tracking ──────────────────────────────────────────────────────────
# Public-facing URL of this backend server, used to generate QR tracking redirect links.
# In production, set this to your actual backend domain (e.g. https://api.yourdomain.com).
# In development, the default http://localhost:3001 works fine.
BACKEND_PUBLIC_URL=http://localhost:3001

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Sign up at https://resend.com → API Keys → Create API Key
# Verify your sending domain in the Resend dashboard.
RESEND_API_KEY=re_your_api_key_here
# The "From" address for outgoing emails (must match your verified Resend domain)
RESEND_FROM=VolunteerFlow <noreply@yourdomain.com>

# ── Payments (Stripe) ─────────────────────────────────────────────────────────
# Sign up at https://stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key
# Stripe webhook signing secret (Developers → Webhooks → your endpoint → Signing secret)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
# Stripe Price IDs — create products in Stripe Dashboard → Products
# Each plan × cycle needs its own price ID
STRIPE_PRICE_DISCOVER_MONTHLY=price_discover_monthly_id
STRIPE_PRICE_DISCOVER_YEARLY=price_discover_yearly_id
STRIPE_PRICE_GROW_MONTHLY=price_grow_monthly_id
STRIPE_PRICE_GROW_YEARLY=price_grow_yearly_id

# ── Payments (PayPal) ──────────────────────────────────────────────────────────
# Sign up at https://developer.paypal.com → My Apps → Create App
# PayPal Subscription Plan IDs — create in PayPal Developer Dashboard → Subscriptions → Plans
PAYPAL_PLAN_DISCOVER_MONTHLY=P-discover_monthly_plan_id
PAYPAL_PLAN_DISCOVER_YEARLY=P-discover_yearly_plan_id
PAYPAL_PLAN_GROW_MONTHLY=P-grow_monthly_plan_id
PAYPAL_PLAN_GROW_YEARLY=P-grow_yearly_plan_id

# ── SMS (Twilio) ───────────────────────────────────────────────────────────────
# Sign up at https://twilio.com → get your Account SID and Auth Token
# Buy a phone number in the Twilio Console.
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
# Twilio phone number in E.164 format (e.g. +12125551234)
TWILIO_PHONE_NUMBER=+12125551234
