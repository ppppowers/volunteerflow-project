# Staff Dashboard (internal employee access)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
STAFF_JWT_SECRET=replace-with-64-char-random-hex-string

# Database
DATABASE_URL=postgresql://volunteerflow:volunteerflow@localhost/volunteerflow

# Server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Bootstrap: run once to create first staff owner
STAFF_OWNER_EMAIL=admin@yourcompany.com
STAFF_OWNER_PASSWORD=changeme_set_strong_password
STAFF_OWNER_NAME=Owner
